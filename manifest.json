{
  "manifest_version": 2,
  "name": "Chat Exporter",
  "version": "1.0.0",
  "description": "Export chats from Claude.ai and Open WebUI as HTML or DOCX",
  "author": "IschNehmDirGleichDemTabletWeg",
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "browser_action": {
    "default_icon": {
      "48": "icons/icon48.png",
      "96": "icons/icon96.png"
    },
    "default_popup": "popup.html",
    "default_title": "Chat Exporter"
  },
  "permissions": [
    "activeTab",
    "downloads"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://claude.ai/*",
        "*://localhost/*",
        "*://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
